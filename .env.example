# --- Database ---
DATABASE_URL="postgresql://hmp:hmp@localhost:5432/hmp?schema=public"

# --- Auth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-prod-use-openssl-rand-base64-32"
AUTH_MODE="credentials" # credentials | sso

# --- SSO (stub, fill when real IdP available) ---
SSO_ISSUER=""
SSO_CLIENT_ID=""
SSO_CLIENT_SECRET=""
SSO_METADATA_URL=""

# --- Storage (MinIO local / S3 prod) ---
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="hmp-handouts"
S3_ACCESS_KEY="hmpaccess"
S3_SECRET_KEY="hmpsecret123"

# --- Email (Mailhog local) ---
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="HMP <no-reply@hmp.local>"

# --- Redis / Queues ---
REDIS_URL="redis://localhost:6379"

# --- Cron / Reminders (M7) ---
# Bearer secret required by /api/cron/reminders. Schedule via Railway/Vercel cron.
CRON_SECRET=""

# --- AI (Phase 2) ---
AI_PROVIDER="openai" # openai | anthropic
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# --- Integrations (Phase 3) ---
ERP_BASE_URL=""
ERP_API_KEY=""
TAXILA_BASE_URL=""
TAXILA_API_KEY=""

# --- App ---
NODE_ENV="development"
LOG_LEVEL="info"
