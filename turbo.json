{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", "tsconfig.base.json"],
  "//": "Turbo 2 runs in strict env mode by default — tasks see ONLY the env vars listed below. Without passThrough, child processes (Next.js dev server, Prisma client, NextAuth) see empty process.env and Prisma throws `Environment variable not found: DATABASE_URL`. Local development hides this because .env files exist on disk; CI does not because they are gitignored. Treat this list as a complement to .env.example — anything declared there should be passed through here.",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "NEXTAUTH_URL",
    "NEXTAUTH_SECRET",
    "AUTH_MODE",
    "SSO_ISSUER",
    "SSO_CLIENT_ID",
    "SSO_CLIENT_SECRET",
    "SSO_METADATA_URL",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_BUCKET",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_USER",
    "SMTP_PASS",
    "SMTP_FROM",
    "REDIS_URL",
    "CRON_SECRET",
    "AI_PROVIDER",
    "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY",
    "ERP_BASE_URL",
    "ERP_API_KEY",
    "TAXILA_BASE_URL",
    "TAXILA_API_KEY",
    "NODE_ENV",
    "LOG_LEVEL",
    "CI"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "e2e": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
