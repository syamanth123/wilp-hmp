// HMP — Prisma schema
// Covers RFP entities: users/roles/permissions, academic structure,
// handout lifecycle, workflow, approvals, AI artifacts, integrations, audit.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// Identity & Access
// =====================================================================

enum RoleName {
  ADMIN
  INSTRUCTION_CELL
  HOG
  PROGRAMME_COMMITTEE
  FACULTY
  SME
}

enum FacultyType {
  ON_CAMPUS
  OFF_CAMPUS
  ADJUNCT
  GUEST
}

model User {
  id                String              @id @default(cuid())
  email             String              @unique
  name              String
  passwordHash      String?
  ssoSubject        String?             @unique
  facultyType       FacultyType?
  active            Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  roles             UserRole[]
  initiatedRequests HandoutRequest[]    @relation("RequestInitiator")
  assignments       FacultyAssignment[]
  approvals         Approval[]
  comments          Comment[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  versionsAuthored  HandoutVersion[]    @relation("VersionAuthor")
  // Prompt 12-b (SME approval workflow). The SME is assigned per handout at
  // allocation; these are the "SME for" and "assigner of" back-relations.
  smeAssignmentsAsSme       SmeAssignment[] @relation("SmeAssignmentsAsSme")
  smeAssignmentsAsAssigner  SmeAssignment[] @relation("SmeAssignmentsAsAssigner")
  corpusImportsApproved     HandoutImport[] @relation("CorpusApprovedBy")
  attachmentsUploaded       Attachment[]    @relation("AttachmentUploader")
  aiUsage                   AiUsageLog[]    @relation("AiUsageActor")

  @@index([email])
}

model Role {
  id          String        @id @default(cuid())
  name        RoleName      @unique
  description String?
  permissions RolePermission[]
  users       UserRole[]
  createdAt   DateTime      @default(now())
}

model Permission {
  id        String           @id @default(cuid())
  key       String           @unique // e.g. "user.create", "handout.approve"
  label     String
  roles     RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// =====================================================================
// Academic Structure
// =====================================================================

model Programme {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  active    Boolean    @default(true)
  semesters Semester[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Semester {
  id          String           @id @default(cuid())
  programmeId String
  name        String           // e.g. "Sem-I 2025-26"
  year        Int
  term        String           // FIRST | SECOND | SUMMER
  startDate   DateTime
  endDate     DateTime
  examDate    DateTime?
  ec1Deadline DateTime?
  programme   Programme        @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  offerings   CourseOffering[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([programmeId, name])
}

model Course {
  id                String           @id @default(cuid())
  // Canonical BITS course identifier — one space between the discipline prefix
  // and the Z[CG]nnn cluster (e.g. "AE ZG631"). Validated/normalized via
  // @hmp/db's normalizeBitsCourseNumber(). Survey-driven (Prompt 11b): 92% of
  // corpus codes match this exact form; the rest are transcription quirks
  // (joined, run-split) collapsed to canonical on insert.
  bitsCourseNumber  String           @unique
  // Equivalent codes for cross-listed / theory+lab-paired courses. 33% of
  // sampled corpus files carry ≥2 codes (AE+AEL pairs, MBA+PDBA+PDFT,
  // CSI+ES+IS+SS cross-listings). Stored canonical-form too.
  alternateCodes    String[]         @default([])
  // Legacy free-form code, kept @unique for back-compat with the CSV importer
  // and admin Course-create action during the transition. Populated equal to
  // bitsCourseNumber by every write path. To be dropped in a later cleanup PR
  // once all callers migrate.
  code              String           @unique
  title             String
  // Optional (matches the 11a optional-field discipline — real handouts often
  // leave the Credit Units cell blank; AEL ZG631 is the documented example).
  credits           Int?
  description       String?
  active            Boolean          @default(true)
  offerings         CourseOffering[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model CourseOffering {
  id            String           @id @default(cuid())
  courseId      String
  semesterId    String
  slotInfo      String?          // class slot
  course        Course           @relation(fields: [courseId], references: [id])
  semester      Semester         @relation(fields: [semesterId], references: [id])
  requests      HandoutRequest[]
  slotBookings  SlotBooking[]
  createdAt     DateTime         @default(now())

  @@unique([courseId, semesterId])
  @@index([semesterId])
}

model SlotBooking {
  id               String         @id @default(cuid())
  courseOfferingId String
  slotType         String         @default("class") // "class" | "exam"
  slot             String
  dayOfWeek        Int
  startTime        String
  endTime          String
  room             String?
  offering         CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())

  @@unique([courseOfferingId, slotType, slot, dayOfWeek, startTime])
}

// =====================================================================
// Handout Lifecycle
// =====================================================================

enum HandoutStatus {
  DRAFT
  REQUESTED
  ALLOCATED
  ASSIGNED
  IN_PROGRESS
  // Prompt 12-a (SME approval workflow): SME approval queue. Sits BETWEEN
  // IN_PROGRESS and SUBMITTED — faculty submit routes here when an
  // SmeAssignment exists; SME approval transitions onward to SUBMITTED
  // (PC's existing review queue). Additive in 12-a; becomes the default
  // submit destination in 12-b. See docs/dev-handoff-audit.md §1.
  SME_REVIEW
  SUBMITTED
  UNDER_REVIEW
  REWORK_REQUESTED
  APPROVED
  PUBLISHED
  ARCHIVED
  REJECTED
}

model HandoutRequest {
  id                  String             @id @default(cuid())
  refNo               String             @unique // human-readable ref like HMP-2025-0001
  courseOfferingId    String
  initiatedById       String
  status              HandoutStatus      @default(REQUESTED)
  notes               String?
  previousHandoutUrl  String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  offering            CourseOffering     @relation(fields: [courseOfferingId], references: [id])
  initiator           User               @relation("RequestInitiator", fields: [initiatedById], references: [id])
  handout             Handout?
  assignments         FacultyAssignment[]
  approvals           Approval[]
  attachments         Attachment[]
  recommendations     AIRecommendation[]
  auditLogs           AuditLog[]
  smeAssignment       SmeAssignment?

  @@index([status])
  @@index([courseOfferingId])
}

model Handout {
  id           String           @id @default(cuid())
  requestId    String           @unique
  currentVersionId String?      @unique
  status       HandoutStatus    @default(DRAFT)
  templateId   String?
  request      HandoutRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  template     Template?        @relation(fields: [templateId], references: [id])
  versions     HandoutVersion[] @relation("HandoutVersions")
  currentVersion HandoutVersion? @relation("CurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  comments     Comment[]
  qualityReports AIQualityReport[]
  aiDraftLogs  AIDraftLog[]
  aiUsage      AiUsageLog[]
  publishLogs  LmsPublishLog[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model HandoutVersion {
  id           String   @id @default(cuid())
  handoutId    String
  versionNo    Int
  contentJson  Json?    // TipTap JSON (legacy — pre-Prompt-11 freeform content). Nullable post-11d: structured handouts don't write this column (data is canonical).
  contentHtml  String   @db.Text // legacy
  partBJson    Json?    // legacy
  evaluativeJson Json?  // legacy
  // Structured BITS handout content conforming to BitsHandoutSchemaV1
  // (@hmp/db handout-schema.ts). Nullable: pre-Prompt-11 rows keep their
  // legacy contentHtml/contentJson and leave this null. New source of truth.
  data         Json?
  authorId     String
  notes        String?
  createdAt    DateTime @default(now())

  handout      Handout  @relation("HandoutVersions", fields: [handoutId], references: [id], onDelete: Cascade)
  current      Handout? @relation("CurrentVersion")
  author       User     @relation("VersionAuthor", fields: [authorId], references: [id])

  @@unique([handoutId, versionNo])
}

model Template {
  id        String   @id @default(cuid())
  name      String   @unique
  contentJson Json
  active    Boolean  @default(true)
  handouts  Handout[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Corpus import (Prompt 11f-a). Each row represents one .docx file ingested
// from the BITS handout corpus. The parser (`packages/db/src/corpus-import/
// parser.ts`) decides how the file was extracted; `extractionMethod` records
// the path taken so the admin UI can filter / re-parse / report.
enum CorpusExtractionMethod {
  // Mammoth structured pass succeeded — tables walked, data populated.
  MAMMOTH_STRUCTURED
  // Mammoth failed; text-fallback (flatten + regex) recovered enough.
  TEXT_FALLBACK
  // Parser ran, returned `data: null`. Specific error in parseErrors.
  FAILED
  // EE-style "Course Modules" template detected — deferred to 11f-b.
  SKIPPED_MODULE
  // >3MB; image-heavy outlier; skipped per the 11a precedent.
  SKIPPED_SIZE
  // Legacy .doc binary or .pdf; mammoth can't parse.
  SKIPPED_FORMAT
  // 11f-b1 finding: 5 corpus files (EE ZG613/623, POM ZG512/522, ST ZG612)
  // use a "narrative-prose" template (Part A as colon-separated prose lines,
  // text books as un-tabled lists). Different parser path; out of scope here.
  SKIPPED_NARRATIVE_PROSE
}

model HandoutImport {
  id                  String   @id @default(cuid())
  // Canonical absolute path of the source file. @unique is the upsert key for
  // idempotency: re-running runCorpusImport on the same file with the same
  // (sourceFileBytes, sourceModifiedAt) is a no-op; a changed file forces
  // re-parse.
  sourceFile          String   @unique
  sourceFileBytes     Int
  sourceModifiedAt    DateTime
  // Extracted course code(s) when parsable. Null when the parser couldn't
  // identify the course (FAILED / SKIPPED_*). @index for the auto-fetch
  // Tier 2 lookup (Prompt 11f-b will read this).
  bitsCourseNumber    String?
  alternateCodes      String[] @default([])
  // BitsHandoutV1 JSON when parse succeeded. Null on FAILED or any SKIPPED_*.
  data                Json?
  // Non-fatal extraction issues (e.g., "Modular Content section ignored;
  // will be addressed in a later prompt").
  parseWarnings       String[] @default([])
  // Fatal parse failures (data is null). Specific reason per file.
  parseErrors         String[] @default([])
  extractionMethod    CorpusExtractionMethod
  // 11f-b approval workflow. Tier 2 in handout-auto-fetch.ts will filter on
  // `approvedForReuse: true AND data IS NOT NULL` so admin review gates
  // surfacing. Stays default false in 11f-a; the approval UI lands in 11f-b.
  approvedForReuse    Boolean  @default(false)
  approvedById        String?
  approvedAt          DateTime?
  approvedBy          User?    @relation("CorpusApprovedBy", fields: [approvedById], references: [id])
  importedAt          DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([bitsCourseNumber])
  @@index([approvedForReuse])
  @@index([extractionMethod])
}

model FacultyAssignment {
  id          String         @id @default(cuid())
  requestId   String
  facultyId   String
  facultyType FacultyType
  active      Boolean        @default(true)
  assignedAt  DateTime       @default(now())
  acceptedAt  DateTime?

  request     HandoutRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  faculty     User           @relation(fields: [facultyId], references: [id])

  @@index([requestId])
  @@index([facultyId])
}

// SME approval workflow (Prompt 12-a/12-b). One SME per handout, assigned by
// the HOG at allocation time, who gates faculty submissions (approve →
// SUBMITTED / PC queue; revert → REWORK_REQUESTED / faculty). Iteration history
// (each approve/revert) lives in Approval(stage=SME_REVIEW) rows, NOT here —
// this table is just the "who is the SME for this handout" pointer, so it
// carries no status or per-decision timestamps. (12-b dropped the earlier
// advisory SmeNomination model this replaced.)
model SmeAssignment {
  id            String         @id @default(cuid())
  requestId     String         @unique // one SME per handout
  request       HandoutRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  smeUserId     String
  smeUser       User           @relation("SmeAssignmentsAsSme", fields: [smeUserId], references: [id])
  assignedById  String // the HOG who made the assignment
  assignedBy    User           @relation("SmeAssignmentsAsAssigner", fields: [assignedById], references: [id])
  assignedAt    DateTime       @default(now())

  @@index([smeUserId])
}

enum ApprovalStage {
  HOG_REVIEW
  // Prompt 12-a: each SME approve/revert decision writes an Approval row
  // at this stage (decision = APPROVED on approve, REWORK on revert).
  // Iteration history lives in these rows — SmeAssignment carries no
  // status/timestamp columns of its own.
  SME_REVIEW
  PC_REVIEW
  HOG_FINAL
  IC_PUBLISH
}

enum ApprovalDecision {
  PENDING
  APPROVED
  REWORK
  REJECTED
}

model Approval {
  id         String           @id @default(cuid())
  requestId  String
  stage      ApprovalStage
  decision   ApprovalDecision @default(PENDING)
  reviewerId String
  comments   String?
  createdAt  DateTime         @default(now())
  decidedAt  DateTime?

  request    HandoutRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  reviewer   User           @relation(fields: [reviewerId], references: [id])

  @@index([requestId, stage])
}

model Comment {
  id         String   @id @default(cuid())
  handoutId  String
  authorId   String
  body       String
  anchor     String?  // for inline anchoring in editor
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  handout    Handout  @relation(fields: [handoutId], references: [id], onDelete: Cascade)
  author     User     @relation(fields: [authorId], references: [id])

  @@index([handoutId])
}

// Handout file attachments (Prompt 16). Request-scoped (supplementary materials
// belong to the handout, not a single draft version — they persist across
// versions). The S3 object key is an opaque UUID (`attachments/<requestId>/<uuid>`);
// the original filename lives here in the DB, never in the key.
model Attachment {
  id          String   @id @default(cuid())
  requestId   String
  uploaderId  String
  filename    String
  mimeType    String
  size        Int
  s3Key       String   @unique
  uploadedAt  DateTime @default(now())

  request     HandoutRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  uploader    User           @relation("AttachmentUploader", fields: [uploaderId], references: [id])

  @@index([requestId])
}

// =====================================================================
// Notifications & Workflow Config
// =====================================================================

enum NotificationChannel {
  IN_PORTAL
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  subject   String
  body      String
  link      String?
  meta      Json?
  createdAt DateTime            @default(now())
  sentAt    DateTime?
  readAt    DateTime?

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model NotificationTemplate {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "handout.submitted"
  subject   String
  body      String   @db.Text
  channels  NotificationChannel[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkflowConfig {
  id              String   @id @default(cuid())
  key             String   @unique
  // SLAs in hours
  hogReviewSla    Int      @default(72)
  pcReviewSla     Int      @default(72)
  facultySubmitSla Int     @default(168)
  hogFinalSla     Int      @default(48)
  offCampusMaxCourses Int  @default(3)
  matrixJson      Json     // approval matrix; configurable
  updatedAt       DateTime @updatedAt
}

// =====================================================================
// AI Artifacts
// =====================================================================

model AIRecommendation {
  id         String   @id @default(cuid())
  requestId  String
  kind       String   // "faculty" | "sme"
  payload    Json     // top-N candidates with rationales/scores
  model      String
  createdAt  DateTime @default(now())

  request    HandoutRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model AIQualityReport {
  id         String   @id @default(cuid())
  handoutId  String
  score      Float
  bloomsJson Json
  coverageJson Json
  suggestions String   @db.Text
  model      String
  createdAt  DateTime @default(now())

  handout    Handout  @relation(fields: [handoutId], references: [id], onDelete: Cascade)
}

model AIDraftLog {
  id         String   @id @default(cuid())
  handoutId  String
  versionNo  Int?     // null = pre-version (preview before Insert), else the version produced by Insert
  source     String   @default("ai") // "ai" | "stub" (template fallback when provider unconfigured)
  payload    Json     // { structured, tiptapJson, model, [promptTokens, completionTokens] }
  model      String
  createdAt  DateTime @default(now())

  handout    Handout  @relation(fields: [handoutId], references: [id], onDelete: Cascade)

  @@index([handoutId, createdAt])
}

// AI cost ledger (Prompt 17). One row per REAL provider call (cache/stub hits
// record nothing — no API call, no cost). Orthogonal to the AI*output* models
// above: those store what the AI produced; this stores what each call cost.
//
// onDelete: SetNull (NOT Cascade) on both FKs — a cost ledger is financial and
// must survive deletion of the user or handout that incurred it. The dashboard
// renders a null user as "system / background" (worker + page-render paths have
// no actor) and a null handout for non-handout operations (recommendations,
// corpus embeddings).
enum AiOperation {
  DRAFT_GENERATION        // generateHandoutDraft (legacy TipTap path)
  STRUCTURED_DRAFT        // generateStructuredHandoutDraft (BitsHandoutV1)
  QUALITY_REPORT          // runQualityReport
  FACULTY_RECOMMENDATION  // embedding calls triggered BY a recommendation run
  EMBEDDING               // embedding calls triggered by admin corpus refresh
}

model AiUsageLog {
  id           String      @id @default(cuid())
  userId       String?     // nullable: worker + page-render paths have no actor
  handoutId    String?     // nullable: recommendations/embeddings aren't handout-scoped
  operation    AiOperation
  provider     String      // client.provider: 'anthropic' | 'openai'
  model        String
  tokensIn     Int         @default(0)
  tokensOut    Int         @default(0)
  costUsd      Decimal     @db.Decimal(12, 6)
  durationMs   Int
  succeeded    Boolean
  errorMessage String?
  createdAt    DateTime    @default(now())

  user    User?    @relation("AiUsageActor", fields: [userId], references: [id], onDelete: SetNull)
  handout Handout? @relation(fields: [handoutId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([handoutId])
  @@index([operation, createdAt])
}

model Embedding {
  id         String   @id @default(cuid())
  ownerType  String   // "Course" | "User"
  ownerId    String
  model      String
  vector     Json     // number[]
  sourceHash String
  createdAt  DateTime @default(now())

  @@unique([ownerType, ownerId, model])
  @@index([ownerType, model])
}

// =====================================================================
// Integration Snapshots
// =====================================================================

model ErpSnapshot {
  id        String   @id @default(cuid())
  source    String   // "csv" | "api"
  payload   Json
  importedBy String?
  createdAt DateTime @default(now())
}

model LmsPublishLog {
  id        String   @id @default(cuid())
  handoutId String
  // Free string by convention (see LmsPublishLogStatus union in @hmp/integrations):
  // "success" | "failed" | "EXPORTED" | "MANUALLY_CONFIRMED". Kept as String so
  // pre-existing rows stay valid without a data migration.
  status    String
  // mode/externalRef/s3Key added in Prompt 9a — all NULLABLE so legacy
  // (stub-era) rows remain valid as null.
  mode         LmsPublishMode?
  externalRef  String?          // HTTP external id (Mode A) or presigned URL (Mode B)
  s3Key        String?          // object key for the export ZIP (Mode B)
  responseJson Json?
  publishedAt DateTime @default(now())

  handout   Handout  @relation(fields: [handoutId], references: [id], onDelete: Cascade)
}

enum LmsPublishMode {
  HTTP
  EXPORT
  MANUALLY_CONFIRMED
}

// =====================================================================
// Audit
// =====================================================================

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String   // e.g. "user.create", "handout.transition"
  entity     String   // entity name
  entityId   String
  before     Json?
  after      Json?
  requestId  String?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor      User?            @relation(fields: [actorId], references: [id], onDelete: SetNull)
  request    HandoutRequest?  @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([actorId])
  @@index([createdAt])
}
